{\n  \"version\": 2,\n  \"builds\": [\n    {\n      \"src\": \"backend/package.json\",\n      \"use\": \"@vercel/node@2.x\",\n      \"config\": {\n        \"maxLambdaSize\": \"50mb\"\n      }\n    },\n    {\n      \"src\": \"frontend/package.json\",\n      \"use\": \"@vercel/static-build\",\n      \"config\": {\n        \"distDir\": \"dist\"\n      }\n    }\n  ],\n  \"routes\": [\n    {\n      \"src\": \"/api/(.*)\",\n      \"dest\": \"backend/dist/server.js\"\n    },\n    {\n      \"src\": \"/(.*)\",\n      \"dest\": \"frontend/dist/index.html\"\n    }\n  ]\n}\n"
